<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Habitat" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Cores principais -->
        <item name="colorPrimary">@color/green_dark</item>
        <item name="colorPrimaryVariant">@color/green_medium</item>
        <item name="colorSecondary">@color/purple</item>

        <!-- Background e Surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Erro -->
        <item name="colorError">@color/error</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>

    <style name="Theme.Habitat" parent="Base.Theme.Habitat" />
</resources>